# ===== 공통 =====
APP_ENV=development            # development | production
TRADING_MODE=paper             # paper | live  (처음 30일은 paper!)
TIMEZONE=Asia/Seoul

# ===== DB =====
POSTGRES_PASSWORD=change_me_strong
DATABASE_URL=postgresql+asyncpg://quantsage:change_me_strong@localhost:5432/quantsage
REDIS_URL=redis://localhost:6379/0

# ===== 거래소 API (출금 권한 반드시 OFF) =====
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
UPBIT_ALLOWED_IPS=127.0.0.1    # 서버 공인 IP

BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
OPENAI_API_KEY=

# ===== 데이터 =====
COINGECKO_API_KEY=
CRYPTOPANIC_API_KEY=
GLASSNODE_API_KEY=

# ===== 알림 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
KAKAO_REST_API_KEY=
DISCORD_WEBHOOK_URL=

# ===== 리스크 (수정 금지 권장) =====
MAX_POSITION_PCT=0.25
MAX_DAILY_LOSS_PCT=0.03
MAX_WEEKLY_LOSS_PCT=0.08
MAX_DRAWDOWN_PCT=0.15
PER_TRADE_RISK_PCT=0.01
KELLY_FRACTION=0.25
VOL_TARGET_ANNUAL=0.20
MIN_CONFIDENCE=0.65
CIRCUIT_BREAKER_5M_PCT=-0.05
ENABLE_LIVE_TRADING=false      # 반드시 false로 시작

# ===== 암호화 (openssl rand -base64 32) =====
MASTER_KEY=

# ===== JWT =====
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ===== Admin =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong
